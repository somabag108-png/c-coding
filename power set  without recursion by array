#include <stdio.h>
#include <math.h>

void powerSet(int arr[], int n) {
    int total = pow(2, n);   // total subsets

    for (int i = 0; i < total; i++) {
        printf("{ ");
        
        for (int j = 0; j < n; j++) {
            // check if jth bit is set
            if (i & (1 << j)) {
                printf("%d ", arr[j]);
            }
        }

        printf("}\n");
    }
}

int main() {
    int arr[] = {1, 2, 3};
    int n = sizeof(arr) / sizeof(arr[0]);

    powerSet(arr, n);

    return 0;
}
